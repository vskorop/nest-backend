generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id String @id @default(uuid())
  email String @unique
  password String 
  createdAt DateTime @default(now()) @map("crated_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  roles Role[]
  token Token[]
  @@map("users")
}

model Token {
  token String @unique
  exp DateTime
  user User @relation(fields: [userId], references: [id])
  userId String
    @@map("tokens")
}

enum Role {
  ADMIN
  USER
}